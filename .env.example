# OpenAI is used only for vector-store upload/search.
# Leave unset for Playwright-only fallback mode without OpenAI vector retrieval.
OPENAI_API_KEY=

# OpenRouter is used for model reasoning/oracle validation and optional Stagehand AI calls.
# Leave unset to use heuristic oracle validation.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://github.com/Rohiths-basement/QA-Agent
OPENROUTER_APP_TITLE=Unified QA Agent

# Default Unified tenant/profile credentials.
UNIFIED_QA_BASE_URL=https://sso.unified-apps.com/login
UNIFIED_QA_WIKI_URL=https://wiki.unified-apps.com/
UNIFIED_QA_EMAIL=
UNIFIED_QA_PASSWORD=
UNIFIED_QA_TENANT=demo
UNIFIED_QA_ROLE=admin

# Optional Stagehand model/runtime settings.
STAGEHAND_ENV=LOCAL
# With OpenRouter + Stagehand, keep the doubled provider prefix so Stagehand's OpenAI-compatible
# SDK sends model id "openai/gpt-5.1-chat" to OpenRouter.
STAGEHAND_MODEL_NAME=openai/openai/gpt-5.1-chat

# Optional Browserbase credentials for a future hosted runtime.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# OpenAI vector-store and OpenRouter oracle/budget settings.
OPENAI_VECTOR_STORE_ID=
QA_ORACLE_MODEL=openai/gpt-5.1-chat
OPENROUTER_ORACLE_ROUTING=auto
# The budget layer chooses the light model for micro/standard runs and permits the heavy model
# only for deep/release runs or explicit overrides.
OPENROUTER_ORACLE_LIGHT_MODEL=openai/gpt-5.1-chat
OPENROUTER_ORACLE_HEAVY_MODEL=openai/gpt-5.5
OPENROUTER_ORACLE_MAX_TOKENS=1200
OPENROUTER_MAX_RUN_COST_USD=25

# Local data/artifact paths.
QA_WIKI_JSONL=data/wiki/articles.jsonl
QA_STORAGE_PATH=.qa/qa-agent.sqlite
QA_ARTIFACT_DIR=artifacts/runs
QA_SAFETY_STEP_LIMIT=80

# Optional tenant profile JSON path.
QA_CREDENTIALS_FILE=.qa/credentials.json

# Cloud/Slack/Hermes control-plane settings.
GCP_PROJECT=
GCP_REGION=us-central1
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Hermes Slack Socket Mode app-level token. Create this in Slack with connections:write.
SLACK_APP_TOKEN=
SLACK_DEFAULT_CHANNEL=
QA_INTERNAL_TOKEN=
QA_MCP_TOKEN=
QA_LIVE_API_URL=
QA_LIVE_ENABLE_STAGEHAND=false
QA_LIVE_SESSION_TTL_MINUTES=45

# GitHub App credentials for private org PR analysis and code graph indexing.
# Prefer base64 for the private key so .env parsing does not mangle newlines.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_PRIVATE_KEY_PATH=
# Optional temporary fallback for indexing/testing before the GitHub App is installed.
GITHUB_TOKEN=
CODEGRAPH_ORG=Unified-Solutions-EMS
CODEGRAPH_MAX_REPOS=18
CODEGRAPH_EMBEDDING_MODEL=text-embedding-3-small
